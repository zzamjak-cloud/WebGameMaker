{
  "name": "web-game-maker",
  "version": "0.0.0",
  "private": true,
  "description": "기획·개발·디자인 직군을 위한 로컬 우선 웹 게임 제작 워크스페이스",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present run typecheck && tsc --project tsconfig.json",
    "test": "pnpm -r --if-present run test && pnpm test:benchmarks",
    "test:benchmarks": "vitest run tests/benchmarks",
    "test:designs": "pnpm --filter @web-game-maker/project-cli test",
    "test:assets": "pnpm --filter @web-game-maker/asset-tools test",
    "coverage": "pnpm --filter @web-game-maker/schema coverage",
    "build": "pnpm -r --if-present run build",
    "generate:schemas": "pnpm --filter @web-game-maker/schema generate:schemas",
    "wgm": "tsx packages/project-cli/src/cli.ts",
    "validate:fixture": "pnpm wgm validate examples/minimal",
    "validate:games": "pnpm wgm validate games/floodgate-07 && pnpm wgm validate games/relay-ward",
    "seed:assets": "tsx packages/asset-tools/scripts/seed-library-assets.ts",
    "measure:reuse": "tsx tests/benchmarks/measure-reuse.ts",
    "measure:reuse:phase4": "tsx tests/benchmarks/phase4-reuse-gate.ts",
    "export:player": "pnpm --filter @web-game-maker/player build && node scripts/export-player.mjs",
    "verify:export": "pnpm export:player && node scripts/verify-export.mjs",
    "package:player": "node scripts/package-player-release.mjs",
    "release:player": "pnpm verify:export && pnpm package:player",
    "verify:release": "pnpm release:player && node scripts/verify-player-release.mjs",
    "serve:export": "node scripts/serve-static-export.mjs --dir exports/player-static --base /release/checkpoint/ --port 4273",
    "test:e2e": "playwright test",
    "test:e2e:export": "playwright test -c playwright.export.config.ts",
    "e2e": "pnpm test:e2e",
    "e2e:export": "pnpm test:e2e:export",
    "visual:update:export": "UPDATE_EXPORT_VISUAL_BASELINE=1 pnpm test:e2e:export --grep @export-visual --project chromium",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm coverage && pnpm generate:schemas && pnpm validate:fixture && pnpm validate:games && pnpm measure:reuse -- --check && pnpm measure:reuse:phase4 && pnpm build && pnpm verify:release && pnpm e2e && pnpm e2e:export"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
