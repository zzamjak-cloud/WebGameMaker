{
  "name": "@web-game-maker/core-modules",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "manifests"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @web-game-maker/module-sdk build && pnpm --filter @web-game-maker/schema build",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json --pretty false",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @web-game-maker/module-sdk build && pnpm --filter @web-game-maker/schema build",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@web-game-maker/module-sdk": "workspace:*",
    "@web-game-maker/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
