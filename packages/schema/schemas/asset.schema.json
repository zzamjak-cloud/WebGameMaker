{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "StableId",
      "description": "저장과 재로딩 뒤에도 유지되는 안정 식별자"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "enum": [
        "image",
        "audio",
        "font",
        "other"
      ]
    },
    "mimeType": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "extension": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16
    },
    "byteSize": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "width": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "height": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "name",
    "type",
    "mimeType",
    "extension",
    "byteSize",
    "sha256",
    "tags"
  ],
  "additionalProperties": false,
  "title": "Asset",
  "description": "아트 리소스 메타데이터 sidecar",
  "$id": "https://schemas.web-game-maker.dev/v1/asset.schema.json"
}
