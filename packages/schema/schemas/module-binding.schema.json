{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "StableId",
      "description": "저장과 재로딩 뒤에도 유지되는 안정 식별자"
    },
    "moduleId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "StableId",
      "description": "저장과 재로딩 뒤에도 유지되는 안정 식별자"
    },
    "enabled": {
      "type": "boolean"
    },
    "targetEntityId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "StableId",
      "description": "저장과 재로딩 뒤에도 유지되는 안정 식별자"
    },
    "config": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      }
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "moduleId",
    "enabled",
    "config"
  ],
  "additionalProperties": false,
  "title": "ModuleBinding",
  "description": "엔티티에 연결한 재사용 모듈 인스턴스와 직렬화 가능한 설정",
  "$defs": {
    "__schema0": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    }
  },
  "$id": "https://schemas.web-game-maker.dev/v1/module-binding.schema.json"
}
